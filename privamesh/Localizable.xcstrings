      }
    },
    "«%@» и вся переписка с ним будут удалены с этого устройства. Контакт по-прежнему сможет тебе написать." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” and all chats with them will be deleted from this device. The contact can still message you."
          }
        }
      }
    },
    "«%@» продан за %@" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” sold for %@"
          }
        }
      }
    },
